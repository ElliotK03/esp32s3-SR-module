CompileFlags:
    CompilationDatabase: build
    BuiltinHeaders: QueryDriver

    Remove:
        [
            "-mlong-calls",
            "-mdisable-hardware-atomics",
            "-fstrict-volatile-bitfields",
            "-fno-tree-switch-conversion",
            "-fzero-init-padding-bits=*",
            "-fno-malloc-dce",
            "-fno-shrink-wrap",
        ]

    Add: [
            # Platform includes
            "-IC:\\esp\\tools\\xtensa-esp-elf\\esp-13.2.0_20240530\\xtensa-esp-elf\\lib\\gcc\\xtensa-esp-elf\\13.2.0\\include",
            "-IC:\\esp\\tools\\xtensa-esp-elf\\esp-13.2.0_20240530\\xtensa-esp-elf\\xtensa-esp-elf\\include",
            # 🔥 Critical: project config
            "-include",

            "build/config/sdkconfig.h",
            # 🔥 ESP-IDF core defines (adjust if not ESP32)
            '-DIDF_VER="v6.0"',
            "-DESP_PLATFORM",
            "-D_GNU_SOURCE",

            # 🔥 Target (IMPORTANT)
            "-DIDF_TARGET_ESP32S3",
            '-DIDF_TARGET="esp32s3"',

            # 🔥 Fix FreeRTOS
            "-include",

            "freertos/FreeRTOS.h",
            # 🔥 Build includes
            "-Ibuild",
            "-Ibuild/esp-idf",

        ]

Index:
    Background: Build
